# Required
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DB
SESSION_SECRET=change-me

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=orders@your-domain.com

# Public site URL (used in emails)
SITE_URL=https://your-app.vercel.app

# Payments (X402)
X402_WALLET_ADDRESS=0xYourBaseUSDCWallet
# Optional separate Solana wallet
X402_SOLANA_WALLET_ADDRESS=YourSolanaUSDCWallet

# Solana network for server-side logic: "solana" | "solana-devnet"
SOLANA_NETWORK=solana

# Optional: seed dev admin locally only
SEED_ADMIN=false

# File uploads (Vercel Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_token

# Coinbase Developer Platform (CDP) — Smart Wallet for agent-controlled contract deployment
# Get API keys at: https://portal.cdp.coinbase.com
CDP_API_KEY_NAME=your-cdp-api-key-name
CDP_API_KEY_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----"
# Set after running: npx tsx scripts/setup-cdp-wallet.ts
CDP_WALLET_ID=
CDP_WALLET_SEED=

# TrustCoat ERC-1155 contract (set after deployment)
TRUST_COAT_ADDRESS=

# Base Sepolia RPC (optional override)
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Basescan API key (for contract verification — get from basescan.org/apis)
BASESCAN_API_KEY=

# Legacy EOA deployer (alternative to CDP wallet)
# DEPLOYER_PRIVATE_KEY=0x...

# Client-side env (Vite)
VITE_HELIUS_API_KEY=your_helius_key
VITE_SOLANA_NETWORK=solana
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
